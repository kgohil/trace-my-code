# CI variant of the trace-my-code freshness hook — bootstrap drops this in by default.
# Runs on PRs; rewrite mode refreshes the affected docs and commits them to the PR branch
# (reviewed in the PR, never pushed to main). Add ANTHROPIC_API_KEY as a repo secret to
# enable rewrite; without it, it safely degrades to flag (comment-only). Set
# TRACE_MY_CODE_MODE: flag below if you want warn-only.
name: doc-drift
on:
  pull_request:
    types: [opened, synchronize]
permissions:
  contents: write
jobs:
  doc-drift:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
          ref: ${{ github.head_ref }}
      - name: Detect doc drift (rewrite by default; degrades to flag without the secret)
        env:
          # rewrite = auto-refresh + commit to the PR branch. Set to 'flag' for warn-only.
          TRACE_MY_CODE_MODE: rewrite
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: |
          git config user.name  "trace-my-code"
          git config user.email "trace-my-code@users.noreply.github.com"
          bash .claude/skills/trace-my-code/hooks/doc-drift.sh || true
      - name: Push doc refresh (rewrite mode only)
        if: ${{ env.TRACE_MY_CODE_MODE == 'rewrite' }}
        run: git push || true
